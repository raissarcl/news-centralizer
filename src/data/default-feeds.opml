    </outline>
    <outline text="AI / ML" title="AI / ML">
      <outline type="rss" text="OpenAI Blog" title="OpenAI Blog" xmlUrl="https://openai.com/blog/rss.xml" htmlUrl="https://openai.com/blog" />
      <outline type="rss" text="Google Research" title="Google Research" xmlUrl="https://research.google/blog/rss/" htmlUrl="https://research.google/blog/" />
    </outline>
    <outline text="Papers" title="Papers">
      <outline type="rss" text="arXiv cs.SE" title="arXiv cs.SE" xmlUrl="https://rss.arxiv.org/rss/cs.SE" htmlUrl="https://arxiv.org/list/cs.SE/recent" />
      <outline type="rss" text="arXiv cs.AI" title="arXiv cs.AI" xmlUrl="https://rss.arxiv.org/rss/cs.AI" htmlUrl="https://arxiv.org/list/cs.AI/recent" />
      <outline type="rss" text="arXiv cs.LG" title="arXiv cs.LG" xmlUrl="https://rss.arxiv.org/rss/cs.LG" htmlUrl="https://arxiv.org/list/cs.LG/recent" />
      <outline type="rss" text="arXiv cs.CL" title="arXiv cs.CL" xmlUrl="https://rss.arxiv.org/rss/cs.CL" htmlUrl="https://arxiv.org/list/cs.CL/recent" />
      <outline type="rss" text="arXiv cs.DC" title="arXiv cs.DC" xmlUrl="https://rss.arxiv.org/rss/cs.DC" htmlUrl="https://arxiv.org/list/cs.DC/recent" />
    </outline>
    <outline text="Brasil" title="Brasil">
<outline type="rss" text="Código em Dia" title="Código em Dia" xmlUrl="https://codigoemdia.substack.com/feed" htmlUrl="https://codigoemdia.substack.com/" />
